{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "/api/index.js" },
    { "src": "/wrapped/(.*)", "dest": "/api/index.js" },
    { "src": "/card/(.*)", "dest": "/api/index.js" },
    { "src": "/compare/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*\\.(html|css|js|png|jpg|ico))", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
